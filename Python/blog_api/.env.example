# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# PostgreSQL connection string using the asyncpg driver.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/blog_db

# Secret key used to sign JWT tokens.
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_string

# JWT algorithm (HS256 is the default, no need to change unless you know why).
ALGORITHM=HS256

# Access token lifetime in minutes (default: 1440 = 24 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=1440
